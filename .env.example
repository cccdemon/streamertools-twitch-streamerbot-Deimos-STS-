# ════════════════════════════════════════════════════════
# CHAOS CREW – Giveaway System v4 – Environment Config
# Kopiere nach .env und passe an
# ════════════════════════════════════════════════════════

# IP des PCs mit Streamerbot
SB_HOST=192.168.178.39
SB_PORT=9090

# SSL Domain
# Leer lassen = HTTP only (Port 80, alle Hosts)
# Domain setzen = automatisches Let's Encrypt SSL
# DOMAIN=stream.example.com
DOMAIN=

# SSL Modus: Caddyfile (HTTP) oder Caddyfile.ssl (HTTPS)
# Leer lassen wenn kein SSL, auf Caddyfile.ssl setzen wenn SSL aktiv
# CADDY_CONFIG=Caddyfile.ssl
CADDY_CONFIG=Caddyfile

# Redis Commander Credentials
REDIS_UI_USER=chaos
REDIS_UI_PASSWORD=crewpassword
